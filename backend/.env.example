# MongoDB Connection String
# Get from: https://cloud.mongodb.com (free tier available)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/infinity-rides?retryWrites=true&w=majority

# JWT Secret - use a long random string
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production

# Server Port
PORT=5000

# Default Admin (created on first seed)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@infinityrides.com
ADMIN_PASSWORD=Admin@12345

# Razorpay (get from https://dashboard.razorpay.com → Settings → API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
